{
  "info": {
    "name": "ZETRC Education Center",
    "_postman_id": "zetrc-education-center-collection",
    "description": "API collection for ZETRC Education Center — Learner Auth + Training Hub CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "description": "Change this to your friend's IP or ngrok URL e.g. http://41.175.23.45:8000"
    }
  ],
  "item": [
    {
      "name": "Learner Authentication",
      "item": [
        {
          "name": "Validate Signup Data",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/portal/validate-signup-data", "host": ["{{base_url}}"], "path": ["portal", "validate-signup-data"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stage_1\": {\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email\": \"learner@example.com\",\n    \"contact_no\": \"097xxxxxxx\",\n    \"password\": \"YourPassword123\",\n    \"password_confirmation\": \"YourPassword123\"\n  }\n}"
            }
          }
        },
        {
          "name": "Submit Learner Registration",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/portal/submit-learner-registration", "host": ["{{base_url}}"], "path": ["portal", "submit-learner-registration"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stage_1\": {\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email\": \"learner@example.com\",\n    \"contact_no\": \"097xxxxxxx\",\n    \"password\": \"YourPassword123\",\n    \"password_confirmation\": \"YourPassword123\"\n  }\n}"
            }
          }
        },
        {
          "name": "Login (Authenticate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/portal/authenticate", "host": ["{{base_url}}"], "path": ["portal", "authenticate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\",\n  \"password\": \"YourPassword123\"\n}"
            }
          }
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/portal/request-otp", "host": ["{{base_url}}"], "path": ["portal", "request-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\"\n}"
            }
          }
        },
        {
          "name": "Validate OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/portal/validate-otp", "host": ["{{base_url}}"], "path": ["portal", "validate-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Verify Signup OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/portal/verify-signup-otp", "host": ["{{base_url}}"], "path": ["portal", "verify-signup-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "CRUD - Course",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/post-data/", "host": ["{{base_url}}"], "path": ["api", "post-data", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Course\",\n  \"body\": {\n    \"name\": \"Python Basics\",\n    \"description\": \"Intro course\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/get-data/?model=Course", "host": ["{{base_url}}"], "path": ["api", "get-data", ""], "query": [{ "key": "model", "value": "Course" }] }
          }
        },
        {
          "name": "Get Single Course",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/get-data/?model=Course&name=Python%20Basics", "host": ["{{base_url}}"], "path": ["api", "get-data", ""], "query": [{ "key": "model", "value": "Course" }, { "key": "name", "value": "Python Basics" }] }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/patch-data/", "host": ["{{base_url}}"], "path": ["api", "patch-data", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Course\",\n  \"body\": {\n    \"name\": \"Python Basics\",\n    \"description\": \"Updated description\"\n  }\n}"
            }
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/delete-doc/", "host": ["{{base_url}}"], "path": ["api", "delete-doc", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Course\",\n  \"body\": {\n    \"name\": \"Python Basics\"\n  }\n}"
            }
          }
        },
        {
          "name": "Submit Course",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/submit-doc/", "host": ["{{base_url}}"], "path": ["api", "submit-doc", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Course\",\n  \"body\": {\n    \"name\": \"Python Basics\"\n  }\n}"
            }
          }
        },
        {
          "name": "Cancel Course",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/cancel-doc/", "host": ["{{base_url}}"], "path": ["api", "cancel-doc", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Course\",\n  \"body\": {\n    \"name\": \"Python Basics\"\n  }\n}"
            }
          }
        }
      ]
